FROM python:3.11-slim

WORKDIR /app

RUN useradd -m -u 10002 sandbox

RUN pip install --no-cache-dir fastapi==0.110.0 uvicorn==0.27.1 pydantic==2.6.3

COPY ultronpro/sandbox_service.py /app/sandbox_service.py

USER sandbox
EXPOSE 9000

CMD ["uvicorn", "sandbox_service:app", "--host", "0.0.0.0", "--port", "9000"]
